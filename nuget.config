<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="ivy-feed" value="https://nuget.pkg.github.com/Ivy-Interactive/index.json" />
  </packageSources>

  <!-- Package source mapping silences NU1507 under Central Package Management
       and makes restore deterministic. All current dependencies are public
       (nuget.org); Ivy.* packages, if added later, resolve from the GitHub feed. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="ivy-feed">
      <package pattern="Ivy.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
